# ===========================
# Dashboards
# =========================== 
### GET 
GET http://localhost:3000/api/getdashboards


### POST
POST http://localhost:3000/api/postdashboards
Content-Type: application/json

{
  "farm_id": "1",
  "farm_name": "test",
  "temperatures": "-10",
  "humidity":"-10",
  "ph": "-10"
}




# ===========================
# Farms
# ===========================
### GET 
GET http://localhost:3000/api/getfarm

### POST
POST http://localhost:3000/api/postfarm
Content-Type: application/json

{
  "farm_name": "Herbal Smart Greenhouse",
  "crop": "โหระพา",
  "areaSize": "6.80",
  "deviceCount": 9,
  "sensorCount": 6,
  "environment": {
    "sunlight": "Greenhouse",
    "temperature": "27°C",
    "humidity": "74%",
    "waterLevel": "88%"
  },
  "location": {
    "lat": 17.4138,
    "lng": 102.7870
  }
}





